
#[CCLVersion("1.0.0")]
#[SerializationType("binary")]

// Basic geometric types
model PositionInfo {
    X: int64;
    Y: int64;
    Z: int64;
}

model RotationInfo {
    X: float32;
    Y: float32;
    Z: float32;
}

model ScaleInfo {
    X: uint32;
    Y: uint32;
    Z: uint32;
}

// Skin related types
model BasicSkin {
    R: uint8;
    G: uint8;
    B: uint8;
}

model TextureSkin {
    Texture: string[];
    SomeIntegers: int64[];
}

// enum SkinType : uint8 {
//     Basic = 0;
//     Texture = 1;
// }

model SkinInfo {
    Type: uint8;
    Basic: BasicSkin;
    Texture: TextureSkin;
}

// User and Room types
model UserInfo {
    Id: string;
    Username: string;
    Skin: SkinInfo;
}

model RoomInfo {
    Slug: string;
    Users: int32;
    MaxUsers: int32;
}

model EntityState {
    Pos: Position;
    Rotation: Rotation;
    Scale: Scale;
    Color: SkinInfo;
}

// Request/Response packets
model AuthGuestRequest {
    RpcId: uint16;
    Username: string;
}

model AuthGuestAnswer {
    RpcId: uint16;
    Token: string;
}

model AuthUserRequest {
    RpcId: uint16;
    Username: string;
    Password: string;
}

model AuthUserAnswer {
    RpcId: uint16;
    Token: string;
}

model AuthWalletRequest {
    RpcId: uint16;
}

model AuthWalletAnswer {
    RpcId: uint16;
    Token: string;
}

model JoinRoomRequest {
    RpcId: uint16;
    RoomId: string;
}

model JoinRoomAnswer {
    RpcId: uint16;
    RoomId: string;
    Room: RoomInfo;
    State: State;
}

model LeaveRoomRequest {
    RpcId: uint16;
    RoomId: string;
}

model LeaveRoomAnswer {
    RpcId: uint16;
    RoomId: string;
}

// Server update messages
model ServerUpdateRoomInfo {
    RoomId: string;
    Users: int32;
}

model ServerUpdateRoomUsers {
    RoomId: string;
    Users: User[];
}

model ServerUpdatePlayerPosition {
    UserId: string;
    Pos: Position;
}

model ServerUpdatePlayerRotation {
    UserId: string;
    Rotation: Rotation;
}

model ServerUpdatePlayerScale {
    UserId: string;
    Scale: Scale;
}

model ServerUpdatePlayerColor {
    UserId: string;
    Color: SkinInfo;
}

model ServerUpdatePlayerSkin {
    UserId: string;
    Skin: SkinInfo;
}

model ServerUpdatePlayerLeave {
    UserId: string;
    }

model ServerUpdatePlayerJoin {
    User: User;
}

model UsersList {
    Users: User[];
    MoreUsers: User[];
}
