// Shared CCL fixture for all code generation tests.
// Add generator feature coverage here when it should apply to every language.

#[CCLVersion("1.0.0")]
#[SerializationType("binary")]
#[SerializationType("json")]
#[$go,$gd,$py,$ts,$cs,$rust:StrictBinaryParsing(false)]
import "imported_definitions.ccl";

#[OutputFileGroup("shared1")]

#namespace:[$cs:OutputFileGroup("my_cs")]

#namespace:[$go:OutputFileGroup("common2")]
#namespace:[$go:OutputFileGroup("common")]

#[$go:OutputFileGroup("shared")]

enum MyCoolEnum {
    Element1,
    Element2,
    Element3,
}

// Basic geometric types
[OutputFileGroup("positions")]
model PositionInfo {
    X: int64;
    Y: int64;
    Z: int64;
}

model RotationInfo {
    X: float32;
    Y: float32;
    Z: float32;
}

model ScaleInfo {
    X: uint32;
    Y: uint32;
    Z: uint32;
}

// Skin related types
model BasicSkin {
    R: uint8;
    G: uint8;
    B: uint8;
}

model TextureSkin {
    Texture: string[];
    SomeInts: int[];
    SomeIntegers: int64[];
}

[OutputFileGroup("skins")]
enum SkinType : uint8 {
    Basic = 0;
    Texture = 1;
}

model SkinInfo {
    Type: SkinType;
    Basic: BasicSkin;
    Texture: TextureSkin;
}

model GameItem {
    [EnumTypeNamePrefix("")]
    [EnumMemberNamePrefix("")]
    enum GameItemType {
        Unknown,
        Gold,
        Gem,
        Exp,
    }

    ItemType: GameItemType;
    Count: int64;
}

model GameShopItem {
    FeaturedType: GameItem.GameItemType;
}

model EmptyModel {
}

model EmptyModelHolder {
    Empty: EmptyModel;
    EmptyItems: EmptyModel[];
}

// UserInfo and RoomInfo types
[OutputFileGroup("users")]
model UserInfo {
    enum UserType {
        Unknown,
        Player,
        Tester,
        Admin,
        Owner,
    }

    [JsonPropertyName("user_id")]
    Id: string;
    Type: UserType = UserType.Player;
    Username: string;
    Skin: SkinInfo;
}

model RoomInfo {
    Slug: string;
    Users: int32;
    MaxUsers: int32;
}

model EntityState {
    Pos: PositionInfo;
    Rotation: RotationInfo;
    Scale: ScaleInfo;
    Color: SkinInfo;
}

// Request/Response packets
model AuthGuestRequest {
    RpcId: uint16;
    Username: string;
}

model SomeTestObj {
    hello: string;
}

model AuthGuestAnswer {
    RpcId: uint16;
    some_property: string;
    some_float: float;
    Success: bool;
    some_bytes: bytes;
    my_field: SomeTestObj;
    Token: string;
}

model AuthUserRequest {
    RpcId: uint16;
    Username: string;
    Password: string;
}

model AuthUserAnswer {
    RpcId: uint16;
    Token: string;
}

model AuthWalletRequest {
    RpcId: uint16;
}

model AuthWalletAnswer {
    RpcId: uint16;
    Token: string;
}

model JoinRoomRequest {
    RpcId: uint16;
    RoomId: string;
}

model JoinRoomAnswer {
    RpcId: uint16;
    RoomId: string;
    Room: RoomInfo;
    State: EntityState;
}

model LeaveRoomRequest {
    RpcId: uint16;
    RoomId: string;
}

model LeaveRoomAnswer {
    RpcId: uint16;
    RoomId: string;
}

// Server update messages
model ServerUpdateRoomInfo {
    RoomId: string;
    Users: int32;
}

model ServerUpdateRoomUsers {
    RoomId: string;
    Users: UserInfo[];
}

model ServerUpdatePlayerPosition {
    UserId: string;
    Pos: PositionInfo;
}

model ServerUpdatePlayerRotation {
    UserId: string;
    Rotation: RotationInfo;
}

model ServerUpdatePlayerScale {
    UserId: string;
    Scale: ScaleInfo;
}

model ServerUpdatePlayerColor {
    UserId: string;
    Color: SkinInfo;
}

model ServerUpdatePlayerSkin {
    UserId: string;
    Skin: SkinInfo;
}

model ServerUpdatePlayerLeave {
    UserId: string;
}

model ServerUpdatePlayerJoin {
    User: UserInfo;
}

model UsersList {
    Users: UserInfo[];
    usernames: string[];
    photos: bytes[];
    something: ServerUpdatePlayerLeave[];
    MoreUsers: UserInfo[];
}

model LooseUserData {
    Level: int;
    Name: string;
    LastQuestDone: int64;
}

[StrictBinaryParsing(true)]
model StrictUserData {
    Level: int;
    Name: string;
    Photo: bytes;
    EmptyStuff: EmptyModel;
    TheLooseOne: LooseUserData;
    EmptyItems: EmptyModel[];
    LooseList: LooseUserData[];
    NormalUser: UserInfo;
    NormalUsers: UserInfo[];
}
